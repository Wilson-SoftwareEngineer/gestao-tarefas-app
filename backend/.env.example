# Copie este arquivo para .env e ajuste com seus valores reais.
# NUNCA versione o .env (já está no .gitignore).

# Profile (dev | prod)
SPRING_PROFILES_ACTIVE=dev

# Banco de dados MySQL
DB_HOST=localhost
DB_PORT=3306
DB_NAME=db_tarefas
DB_USER=root
DB_PASSWORD=troque-esta-senha

# Origens permitidas pelo CORS (separadas por vírgula)
CORS_ORIGINS=http://localhost:4200
